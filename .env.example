APP_CONTAINER_NAME=logmonitor-app
APP_HOST=0.0.0.0
APP_PORT=8080
API_AUTH_TOKEN=
AUTH_VALUE_ENCRYPTION_KEY=change-me-auth-value-encryption-key
INTEGRITY_HMAC_KEY=change-me-integrity-hmac-key

POSTGRES_CONTAINER_NAME=logmonitor-postgres
POSTGRES_PORT=5432
POSTGRES_DB=logmonitor
POSTGRES_USER=logmonitor
POSTGRES_PASSWORD=logmonitor
DB_SSLMODE=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=1
DB_MIGRATIONS_DIR=migrations

SSH_CONNECT_TIMEOUT_SECONDS=10
SSH_COMMAND_TIMEOUT_SECONDS=30
SSH_KNOWN_HOSTS_PATH=
SSH_INSECURE_IGNORE_HOST_KEY=true

DISCOVERY_CRON="0 */6 * * *"
COLLECTION_CRON="*/5 * * * *"
INTEGRITY_CRON="0 * * * *"

COLLECTOR_BATCH_SIZE=5000
COLLECTOR_CHUNK_SIZE=1000
COLLECTOR_STORE_RAW_CONTENT=true
COLLECTOR_CHUNK_HASH_ALGO=sha256

HEALTH_FAILURE_THRESHOLD=1
HEALTH_BACKOFF_BASE_SECONDS=60
HEALTH_BACKOFF_MAX_SECONDS=900
HEALTH_LAST_ERROR_MAX_LENGTH=2048

WORKERS_DISCOVERY_SERVERS=4
WORKERS_COLLECTION_SERVERS=4
WORKERS_COLLECTION_LOG_FILES_PER_HOST=2
WORKERS_INTEGRITY_SERVERS=2
WORKERS_INTEGRITY_LOG_FILES_PER_HOST=1
WORKERS_PER_SERVER_ISOLATION=true
